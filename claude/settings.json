{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/shell/require-test.sh"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "denyWrite": [".git", ".env.*"]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": ["localhost"]
    }
  }
}
